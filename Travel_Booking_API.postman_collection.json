{
  "info": {
    "name": "Travel Booking API",
    "description": "Complete collection for the Travel Booking REST API.\n\n## Setup\n1. Import this collection and the environment file `Travel_Booking_API.postman_environment.json`\n2. Run **Login as Admin**, **Login as Customer**, **Login as Agent** — tokens are saved automatically\n3. Use the requests with the matching role\n\n## Test credentials\n- ADMIN    : admin@travel.com / password\n- CUSTOMER : customer@travel.com / password\n- AGENT    : agent@travel.com / password",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",       "value": "https://itu-m2-rest-api-spring-boot.onrender.com" },
    { "key": "admin_token",    "value": "" },
    { "key": "customer_token", "value": "" },
    { "key": "agent_token",    "value": "" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New User\",\n  \"email\": \"newuser@travel.com\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Login as Admin",
          "event": [{ "listen": "test", "script": { "exec": [
            "const res = pm.response.json();",
            "if (res.token) { pm.collectionVariables.set('admin_token', res.token); pm.test('Admin token saved', () => pm.expect(res.token).to.be.a('string')); }"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@travel.com\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Login as Customer",
          "event": [{ "listen": "test", "script": { "exec": [
            "const res = pm.response.json();",
            "if (res.token) { pm.collectionVariables.set('customer_token', res.token); pm.test('Customer token saved', () => pm.expect(res.token).to.be.a('string')); }"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@travel.com\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Login as Agent",
          "event": [{ "listen": "test", "script": { "exec": [
            "const res = pm.response.json();",
            "if (res.token) { pm.collectionVariables.set('agent_token', res.token); pm.test('Agent token saved', () => pm.expect(res.token).to.be.a('string')); }"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"agent@travel.com\",\n  \"password\": \"password\"\n}"
            }
          }
        }
      ]
    },

